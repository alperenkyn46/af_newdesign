# ===========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ===========================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# cp .env.example .env

# ===========================================
# DATABASE - PostgreSQL
# ===========================================
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://betvip:GÜÇLÜ_ŞİFRE_BURAYA@localhost:5432/betvip_db"

# ===========================================
# NEXTAUTH - Authentication
# ===========================================
# Güçlü bir secret key oluşturun: openssl rand -base64 32
NEXTAUTH_SECRET="BURAYA_GÜÇLÜ_BİR_SECRET_KEY_YAZIN"

# Production domain'iniz (https ile)
NEXTAUTH_URL="https://yourdomain.com"

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV="production"
